# ──────────────────────────────────────────────────────────────────────────────
# AGENDAMENTO AUTOMATIZADO — Clínica NeuroViva
# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA commite o .env.local no repositório.
# ──────────────────────────────────────────────────────────────────────────────

# ── Google Calendar (Service Account) ────────────────────────────────────────
#
# PASSO A PASSO:
# 1. Acesse console.cloud.google.com
# 2. Crie um projeto (ex: "neuroviva-agenda")
# 3. Ative a API: APIs & Services → Library → "Google Calendar API" → Enable
# 4. Crie a Service Account: IAM & Admin → Service Accounts → Create
# 5. Clique na SA criada → Keys → Add Key → JSON → faça o download
# 6. No Google Calendar do médico: Configurações → "Integrar agenda"
#    → Compartilhar com pessoas → adicione o e-mail da SA com permissão
#    "Fazer alterações nos eventos"
#
GOOGLE_SERVICE_ACCOUNT_EMAIL=neuroviva-agenda@seu-projeto.iam.gserviceaccount.com

# Cole o valor de "private_key" do JSON baixado.
# IMPORTANTE: substitua as quebras de linha reais por \n (literal) para que
# o valor caiba em uma linha. Deve começar e terminar com as aspas abaixo.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...resto da chave...\n-----END PRIVATE KEY-----\n"

# ID do calendário onde os eventos serão criados.
# Encontrado em: Google Calendar → Configurações → "Integrar agenda" → ID do calendário
# Para o calendário principal, geralmente é o e-mail do médico.
GOOGLE_CALENDAR_ID=medico@gmail.com

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
#
# PASSO A PASSO:
# 1. Crie uma conta em twilio.com
# 2. No Console, copie o Account SID e o Auth Token
# 3. Para testes: use o WhatsApp Sandbox
#    → Messaging → Try it out → Send a WhatsApp message
#    → O médico precisa enviar "join <palavra>" para o número do sandbox
# 4. Para produção: solicite um número aprovado pelo WhatsApp Business
#    → Messaging → Senders → WhatsApp Senders
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número remetente do Twilio (sandbox ou aprovado)
# Sandbox: whatsapp:+14155238886
# Produção: whatsapp:+5511XXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Número WhatsApp do médico que receberá as notificações
# Formato: whatsapp:+55 + DDD + número (sem espaços ou traços)
DOCTOR_WHATSAPP=whatsapp:+5511999999999
